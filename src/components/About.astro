---
import { site } from '../data/site';

// Capability columns derived strictly from the two real case studies.
const capabilities = [
  {
    head: 'Product engineering',
    body: 'Layered React + TypeScript frontends with business logic kept out of components — pages → context → services. Multi-tenant data models secured at the database, not just the UI.',
  },
  {
    head: 'AI / agentic systems',
    body: 'Multi-agent RAG pipelines on LangGraph: hybrid retrieval (BM25 + vector) fused with reciprocal rank fusion, MCP-exposed tools, and guardrails treated as first-class, not an afterthought.',
  },
  {
    head: 'Ship & operate',
    body: 'Continuous deploy gated by real journey tests that assert the actual outcome — the row persisted, the email sent — not a green status pill. Cloud-native on Supabase and AWS.',
  },
];
---
<section id="about" class="about">
  <div class="shell about-grid">
    <div class="about-lead reveal">
      <p class="kicker">/ About</p>
      <p class="about-statement display">
        I care about the <em>whole</em> system — the part between the tools where
        real work leaks out.
      </p>
      <div class="about-prose">
        <!-- Bio grounded in the two shipped case studies. First-person AND studio-aware:
             the owner is the person behind the studio (hybrid framing) — not a faceless
             "we". Owner can swap in their own. -->
        <p>
          I'm the engineer behind the studio — a full-stack and AI engineer who likes
          building products that actually run in production, with real users, real payments,
          and real consequences when something breaks. Recently that's meant a construction
          operating system used by contractors, and an agentic system that makes Federal
          Reserve data answerable in plain English.
        </p>
        <p>
          Both were team efforts, and I think that's the point: the interesting engineering
          shows up where systems and people meet. I'm drawn to honest tests, data-layer
          security, and architectures that stay legible as they grow.
        </p>
      </div>
    </div>

    <ul class="about-caps">
      {capabilities.map((c, i) => (
        <li class="cap reveal" style={`transition-delay:${i * 80}ms`}>
          <span class="cap-num font-mono tnum">{String(i + 1).padStart(2, '0')}</span>
          <div>
            <h3 class="cap-head">{c.head}</h3>
            <p class="cap-body">{c.body}</p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .about { position: relative; z-index: 2; padding-top: clamp(5rem, 11vw, 9rem); }
  .about-grid { display: grid; grid-template-columns: 1fr 0.85fr; gap: clamp(2.5rem, 7vw, 6rem); align-items: start; }
  @media (max-width: 880px) { .about-grid { grid-template-columns: 1fr; gap: 3rem; } }

  .about-statement { font-size: clamp(1.8rem, 4.5vw, 3rem); color: var(--color-paper); margin: 1.2rem 0 2rem; line-height: 1.08; }
  .about-statement em { color: var(--color-amber); font-style: italic; }
  .about-prose { color: var(--color-paper-dim); max-width: 52ch; font-size: 1.05rem; }
  .about-prose p + p { margin-top: 1.1rem; }

  .about-caps { list-style: none; margin: 0; padding: 0; }
  .cap { display: grid; grid-template-columns: auto 1fr; gap: 1.2rem; padding: 1.6rem 0; border-top: 1px solid var(--color-line); }
  .cap:last-child { border-bottom: 1px solid var(--color-line); }
  .cap-num { color: var(--color-amber); font-size: 0.8rem; padding-top: 0.25rem; }
  .cap-head { font-size: 1.12rem; color: var(--color-paper); margin: 0 0 0.5rem; font-weight: 600; }
  .cap-body { color: var(--color-paper-dim); font-size: 0.96rem; margin: 0; line-height: 1.55; }
</style>
