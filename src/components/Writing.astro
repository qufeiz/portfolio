---
// Home-page "Writing" highlight — a CURATED slice (top few articles, hub first)
// of the writing, NOT the full list. The full index lives at /writing; the
// "View all writing" link below sends readers there. Reads the `articles`
// content collection (the KB). Keeps the home a fixed, curated size.
//
// The section is GENERAL "Writing" (essays, project write-ups, life, notes) —
// its name lives in WRITING_SECTION (src/data/site.ts) so it's a one-word swap
// to "Blog" later. The currently-featured pieces happen to be the agent-systems
// essays (that's the current content + the thesis), but the framing is general.
import { recentArticles, publishedArticles } from '../lib/content';
import { link } from '../lib/url';
import { WRITING_SECTION, categoryLabel } from '../data/site';

const articles = await recentArticles(3);
const total = (await publishedArticles()).length;

const kindLabel: Record<string, string> = {
  hub: 'Hub',
  concept: 'Concept',
  team: 'Team',
};
---
<section id="writing" class="agents">
  <div class="shell">
    <header class="agents-head reveal">
      <p class="kicker">/ {WRITING_SECTION}</p>
      <h2 class="display agents-title">{WRITING_SECTION} —<br />essays &amp; notes.</h2>
      <p class="agents-note">
        Writing on the systems I build, the projects I ship, and what I'm learning
        along the way. The throughline right now is agent systems — built on one
        architecture: orchestrate&nbsp;→&nbsp;gate&nbsp;→&nbsp;ratchet.
      </p>
    </header>

    <ol class="ag-list">
      {articles.map((a) => (
        <li class={`ag-item reveal ${a.data.kind === 'hub' ? 'ag-hub' : ''}`}>
          <a href={link(`notes/${a.id}`)} class="ag-link" aria-label={`Read: ${a.data.title}`}>
            <div class="ag-index font-mono tnum">{String(a.data.order).padStart(2, '0')}</div>

            <div class="ag-body">
              <div class="ag-top">
                <h3 class="display ag-name">{a.data.title}</h3>
                <span class="ag-cat font-mono">{categoryLabel(a.data.category)}</span>
                <span class={`ag-kind font-mono kind-${a.data.kind}`}>{kindLabel[a.data.kind] ?? a.data.kind}</span>
              </div>
              <p class="ag-deck">{a.data.deck}</p>
              {a.data.tags.length > 0 && (
                <div class="ag-tags">
                  {a.data.tags.slice(0, 5).map((t) => <span class="chip">{t}</span>)}
                </div>
              )}
            </div>

            <div class="ag-go" aria-hidden="true">
              <span class="ag-arrow">→</span>
            </div>
          </a>
        </li>
      ))}
    </ol>

    <a href={link('writing')} class="view-all reveal link-spark">
      View all writing <span aria-hidden="true">→</span>
      {total > articles.length && <span class="view-all-n font-mono">({total})</span>}
    </a>
  </div>
</section>

<style>
  .agents { position: relative; z-index: 2; padding-top: clamp(5rem, 11vw, 9rem); }
  .agents-head { max-width: 680px; margin-bottom: clamp(2.5rem, 6vw, 4.5rem); }
  .agents-title { font-size: clamp(2.4rem, 7vw, 4.5rem); margin: 1rem 0 0; color: var(--color-paper); }
  .agents-note { margin-top: 1.4rem; color: var(--color-paper-dim); max-width: 58ch; font-size: 1.02rem; }

  .ag-list { list-style: none; margin: 0; padding: 0; border-top: 1px solid var(--color-line); }
  .ag-item { border-bottom: 1px solid var(--color-line); }

  .ag-link {
    display: grid;
    grid-template-columns: 84px 1fr auto;
    gap: clamp(1rem, 4vw, 3rem);
    align-items: start;
    padding: clamp(1.8rem, 4vw, 3rem) 0;
    position: relative;
    transition: padding-left 0.35s cubic-bezier(0.22,1,0.36,1);
  }
  .ag-link::before {
    content: ""; position: absolute; left: 0; top: 0; bottom: 0; width: 2px;
    background: var(--color-spark); transform: scaleY(0); transform-origin: top;
    transition: transform 0.4s cubic-bezier(0.22,1,0.36,1);
  }
  .ag-link:hover { padding-left: 1.5rem; }
  .ag-link:hover::before { transform: scaleY(1); }

  /* The hub gets a subtle amber spine to read as the umbrella entry. */
  .ag-hub .ag-link::before { background: var(--color-amber); }

  .ag-index { font-size: clamp(1.4rem, 3vw, 2rem); color: var(--color-paper-mute); line-height: 1; padding-top: 0.35rem; }
  .ag-link:hover .ag-index { color: var(--color-spark); }
  .ag-hub .ag-link:hover .ag-index { color: var(--color-amber); }

  .ag-body { min-width: 0; }
  .ag-top { display: flex; align-items: baseline; gap: 1rem; flex-wrap: wrap; }
  .ag-name { font-size: clamp(1.8rem, 4.5vw, 2.9rem); color: var(--color-paper); line-height: 1; }
  /* Category badge — the primary axis; amber-tinted to read as the framing. */
  .ag-cat {
    font-size: 0.62rem; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--color-amber); border: 1px solid color-mix(in srgb, var(--color-amber) 45%, transparent);
    padding: 0.22rem 0.5rem; border-radius: 2px;
  }
  .ag-kind {
    font-size: 0.62rem; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--color-paper-mute); border: 1px solid var(--color-line-2);
    padding: 0.22rem 0.5rem; border-radius: 2px;
  }
  .kind-hub { color: var(--color-ink); background: var(--color-amber); border-color: var(--color-amber); }
  .kind-concept { color: var(--color-spark); border-color: var(--color-line-2); }
  .ag-deck { margin: 1rem 0 0; color: var(--color-paper); font-size: clamp(1.02rem, 2vw, 1.25rem); max-width: 50ch; line-height: 1.35; }
  .ag-tags { display: flex; flex-wrap: wrap; gap: 0.45rem; margin-top: 1.4rem; }

  .view-all {
    display: inline-flex; align-items: baseline; gap: 0.5rem;
    margin-top: clamp(2rem, 5vw, 3rem);
    font-family: var(--font-mono); font-size: 0.86rem; letter-spacing: 0.02em;
  }
  .view-all-n { color: var(--color-paper-mute); font-size: 0.78rem; }

  .ag-go { display: flex; align-items: center; padding-top: 0.6rem; }
  .ag-arrow { font-size: 1.6rem; color: var(--color-paper-dim); transition: transform 0.3s ease, color 0.2s ease; }
  .ag-link:hover .ag-arrow { transform: translateX(6px); color: var(--color-spark); }
  .ag-hub .ag-link:hover .ag-arrow { color: var(--color-amber); }

  @media (max-width: 720px) {
    .ag-link { grid-template-columns: 1fr; gap: 0.5rem; }
    .ag-index { font-size: 1.1rem; }
    .ag-go { display: none; }
  }
</style>
