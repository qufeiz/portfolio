---
// /work — the dedicated index of ALL projects (the "Work" tab).
// Source of truth: src/data/projects.ts. Scale-ready: featured first, then by
// `order` (ascending). Reads cleanly at 2 projects and at 50; the home page
// shows only the curated featured few, so this list can grow without bloating
// the home.
//
// TODO: paginate at N (~24). When the project count crosses that, slice into
// pages (e.g. /work/2) or add a tag/year filter rail — same pattern as /writing.
import Base from '../../layouts/Base.astro';
import { sortedProjects } from '../../data/projects';
import { link } from '../../lib/url';
import { site } from '../../data/site';

const projects = sortedProjects();
---
<Base
  title={`Case studies · ${site.name}`}
  description="Client builds the studio has shipped — software and automations in production, with the full problem → approach → architecture breakdown on each case page."
>
  <section class="work-index">
    <div class="shell">
      <header class="wx-head rise">
        <p class="kicker">/ Case studies · {projects.length} {projects.length === 1 ? 'build' : 'builds'}</p>
        <h1 class="display wx-title">What the<br />studio has shipped.</h1>
        <p class="wx-note">
          Client builds shipped to real users, credited honestly. Click any case study for
          the full problem → approach → architecture breakdown.
        </p>
      </header>

      <ol class="wx-list">
        {projects.map((p) => (
          <li class={`wx-item reveal accent-${p.accent}`}>
            <a href={link(`work/${p.slug}`)} class="wx-link" aria-label={`Open case study: ${p.title}`}>
              <div class="wx-index font-mono tnum">{p.index}</div>

              <div class="wx-body">
                <div class="wx-top">
                  <h2 class="display wx-name">{p.title}</h2>
                  <span class="wx-status font-mono">{p.status}</span>
                  {p.featured && <span class="wx-flag font-mono">Featured</span>}
                </div>
                <p class="wx-tag">{p.tagline}</p>
                <p class="wx-context font-mono">↳ {p.context}</p>
                <div class="wx-stack">
                  {p.stack.slice(0, 6).map((s) => <span class="chip">{s}</span>)}
                  {p.stack.length > 6 && <span class="chip chip-more">+{p.stack.length - 6}</span>}
                </div>
                {p.tags.length > 0 && (
                  <div class="wx-tags" aria-label="Tags">
                    {p.tags.map((t) => <span class="tag-chip font-mono">#{t}</span>)}
                  </div>
                )}
              </div>

              <div class="wx-go" aria-hidden="true">
                <span class="wx-go-label font-mono">{p.year}</span>
                <span class="wx-arrow">→</span>
              </div>
            </a>
          </li>
        ))}
      </ol>
    </div>
  </section>
</Base>

<style>
  .work-index { position: relative; z-index: 2; padding-top: clamp(2.5rem, 7vw, 5rem); }
  .wx-head { max-width: 660px; margin-bottom: clamp(2.5rem, 6vw, 4.5rem); }
  .wx-title { font-size: clamp(2.6rem, 8vw, 5rem); margin: 1rem 0 0; color: var(--color-paper); }
  .wx-note { margin-top: 1.4rem; color: var(--color-paper-dim); max-width: 54ch; font-size: 1.02rem; }

  .wx-list { list-style: none; margin: 0; padding: 0; border-top: 1px solid var(--color-line); }
  .wx-item { border-bottom: 1px solid var(--color-line); }

  .wx-link {
    display: grid;
    grid-template-columns: 84px 1fr auto;
    gap: clamp(1rem, 4vw, 3rem);
    align-items: start;
    padding: clamp(1.8rem, 4vw, 3rem) 0;
    position: relative;
    transition: padding-left 0.35s cubic-bezier(0.22,1,0.36,1);
  }
  .wx-link::before {
    content: ""; position: absolute; left: 0; top: 0; bottom: 0; width: 2px;
    background: var(--color-amber); transform: scaleY(0); transform-origin: top;
    transition: transform 0.4s cubic-bezier(0.22,1,0.36,1);
  }
  .accent-spark .wx-link::before { background: var(--color-spark); }
  .wx-link:hover { padding-left: 1.5rem; }
  .wx-link:hover::before { transform: scaleY(1); }

  .wx-index { font-size: clamp(1.4rem, 3vw, 2rem); color: var(--color-paper-mute); line-height: 1; padding-top: 0.35rem; }
  .accent-spark .wx-link:hover .wx-index { color: var(--color-spark); }
  .accent-amber .wx-link:hover .wx-index { color: var(--color-amber); }

  .wx-body { min-width: 0; }
  .wx-top { display: flex; align-items: baseline; gap: 0.8rem; flex-wrap: wrap; }
  .wx-name { font-size: clamp(2rem, 5vw, 3.2rem); color: var(--color-paper); line-height: 1; }
  .wx-status {
    font-size: 0.68rem; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--color-ink); background: var(--color-amber); padding: 0.22rem 0.55rem; border-radius: 2px;
  }
  .accent-spark .wx-status { background: var(--color-spark); }
  .wx-flag {
    font-size: 0.62rem; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--color-paper-mute); border: 1px solid var(--color-line-2);
    padding: 0.2rem 0.5rem; border-radius: 2px;
  }
  .wx-tag { margin: 1rem 0 0; color: var(--color-paper); font-size: clamp(1.05rem, 2vw, 1.32rem); max-width: 42ch; line-height: 1.35; }
  .wx-context { margin: 0.8rem 0 0; color: var(--color-paper-mute); font-size: 0.8rem; max-width: 60ch; }
  .wx-stack { display: flex; flex-wrap: wrap; gap: 0.45rem; margin-top: 1.4rem; }
  .chip-more { color: var(--color-paper-mute); }
  .wx-tags { display: flex; flex-wrap: wrap; gap: 0.5rem 0.9rem; margin-top: 1rem; }
  .tag-chip { font-size: 0.72rem; color: var(--color-paper-mute); letter-spacing: 0.02em; }

  .wx-go { display: flex; flex-direction: column; align-items: flex-end; gap: 0.8rem; padding-top: 0.5rem; }
  .wx-go-label { font-size: 0.72rem; color: var(--color-paper-mute); letter-spacing: 0.1em; }
  .wx-arrow { font-size: 1.6rem; color: var(--color-paper-dim); transition: transform 0.3s ease, color 0.2s ease; }
  .wx-link:hover .wx-arrow { transform: translateX(6px); color: var(--color-amber); }
  .accent-spark .wx-link:hover .wx-arrow { color: var(--color-spark); }

  @media (max-width: 720px) {
    .wx-link { grid-template-columns: 1fr; gap: 0.5rem; }
    .wx-index { font-size: 1.1rem; }
    .wx-go { flex-direction: row; align-items: center; justify-content: space-between; margin-top: 1.2rem; }
  }
</style>
