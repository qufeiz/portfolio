---
// Dynamic article page — renders one article from the `articles` content
// collection with the design system. The KB (src/content/articles) is the
// source of truth; this file only renders it.
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { site } from '../../data/site';
import { link } from '../../lib/url';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => !data.draft);
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);

// "Up next" — the next article by order (wraps to none at the end).
const all = (await getCollection('articles', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order,
);
const idx = all.findIndex((a) => a.id === article.id);
const next = all[idx + 1];

const kindLabel: Record<string, string> = {
  hub: 'Hub',
  concept: 'Concept',
  team: 'Team',
};
---
<Base
  title={`${article.data.title} — Agent Systems · ${site.name}`}
  description={article.data.deck}
>
  <article class="note">
    <!-- Header -->
    <header class="note-head">
      <div class="shell">
        <a href={link('/#agents')} class="note-back font-mono">← Agent Systems</a>

        <div class="note-top">
          <span class="note-kind font-mono">{kindLabel[article.data.kind] ?? article.data.kind}</span>
          <h1 class="display note-title">{article.data.title}</h1>
          <p class="note-deck">{article.data.deck}</p>
          {article.data.tags.length > 0 && (
            <div class="note-tags">
              {article.data.tags.map((t) => <span class="chip">{t}</span>)}
            </div>
          )}
        </div>
      </div>
      <div class="shell"><div class="rule note-rule"></div></div>
    </header>

    <!-- Body (rendered markdown) -->
    <div class="shell">
      <div class="note-body reveal">
        <Content />
      </div>

      {article.data.keyTakes.length > 0 && (
        <section class="takes reveal" aria-label="Key takes">
          <p class="kicker takes-kicker">/ Key takes</p>
          <ul class="takes-list">
            {article.data.keyTakes.map((t) => <li class="take">{t}</li>)}
          </ul>
        </section>
      )}

      {next && (
        <nav class="note-next reveal" aria-label="Next article">
          <a href={link(`notes/${next.id}`)} class="next-link">
            <span class="next-k font-mono">Next →</span>
            <span class="next-title display">{next.data.title}</span>
          </a>
        </nav>
      )}
    </div>
  </article>
</Base>

<style>
  .note { position: relative; z-index: 2; }

  .note-head { padding-top: clamp(2.5rem, 6vw, 4.5rem); }
  .note-back { display: inline-block; font-size: 0.8rem; color: var(--color-paper-mute); margin-bottom: clamp(2rem, 5vw, 3.5rem); transition: color 0.2s ease; }
  .note-back:hover { color: var(--color-spark); }

  .note-top { max-width: 760px; }
  .note-kind {
    font-size: 0.62rem; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--color-spark); border: 1px solid var(--color-line-2);
    padding: 0.24rem 0.55rem; border-radius: 2px;
  }
  .note-title { font-size: clamp(2.6rem, 8vw, 5rem); color: var(--color-paper); margin: 1.2rem 0 0; }
  .note-deck { margin: 1.4rem 0 0; font-size: clamp(1.15rem, 2.4vw, 1.6rem); color: var(--color-paper-dim); max-width: 46ch; line-height: 1.3; font-family: var(--font-display); font-style: italic; font-weight: 380; }
  .note-tags { display: flex; flex-wrap: wrap; gap: 0.45rem; margin-top: 1.8rem; }
  .note-rule { margin-top: clamp(3rem, 7vw, 5rem); }

  /* Article prose — tuned to the design system. Single column, readable measure. */
  .note-body { max-width: 70ch; margin: clamp(2.5rem, 6vw, 4rem) 0 0; }

  .note-body :global(h2) {
    font-family: var(--font-display); font-weight: 540; letter-spacing: -0.02em;
    font-size: clamp(1.5rem, 3vw, 2.1rem); color: var(--color-paper);
    line-height: 1.08; margin: clamp(2.5rem, 5vw, 3.5rem) 0 1.2rem;
  }
  .note-body :global(h3) {
    font-family: var(--font-display); font-weight: 540;
    font-size: clamp(1.2rem, 2.2vw, 1.5rem); color: var(--color-paper);
    margin: 2rem 0 0.9rem;
  }
  .note-body :global(p) { color: var(--color-paper-dim); font-size: clamp(1.04rem, 1.5vw, 1.18rem); line-height: 1.7; margin: 0 0 1.25rem; }
  .note-body :global(strong) { color: var(--color-paper); font-weight: 600; }
  .note-body :global(em) { color: var(--color-amber); font-style: italic; }
  .note-body :global(a) { color: var(--color-spark); text-decoration: underline; text-underline-offset: 3px; text-decoration-color: color-mix(in srgb, var(--color-spark) 45%, transparent); }
  .note-body :global(a:hover) { text-decoration-color: var(--color-spark); }

  .note-body :global(ul), .note-body :global(ol) { margin: 0 0 1.25rem; padding: 0; list-style: none; }
  .note-body :global(li) { position: relative; padding-left: 1.5rem; margin-bottom: 0.85rem; color: var(--color-paper-dim); font-size: clamp(1.02rem, 1.5vw, 1.12rem); line-height: 1.6; }
  .note-body :global(li::before) { content: "▸"; position: absolute; left: 0; color: var(--color-amber); }
  .note-body :global(li strong) { color: var(--color-paper); }

  .note-body :global(blockquote) {
    margin: 1.6rem 0; padding: 0.9rem 1.4rem;
    border-left: 2px solid var(--color-amber);
    background: var(--color-ink-2);
    color: var(--color-paper); font-family: var(--font-mono); font-size: 0.92rem;
  }
  .note-body :global(blockquote p) { margin: 0; color: var(--color-paper); }

  /* Inline + block code */
  .note-body :global(code) {
    font-family: var(--font-mono); font-size: 0.85em;
    background: var(--color-ink-3); border: 1px solid var(--color-line);
    padding: 0.08em 0.38em; border-radius: 2px; color: var(--color-paper);
  }
  .note-body :global(pre) {
    margin: 1.5rem 0; padding: 1.1rem 1.3rem; overflow-x: auto;
    background: var(--color-ink-2); border: 1px solid var(--color-line);
    border-radius: var(--radius); font-size: 0.86rem; line-height: 1.55;
  }
  .note-body :global(pre code) { background: none; border: 0; padding: 0; color: inherit; }

  /* Key takes block */
  .takes {
    margin: clamp(3rem, 7vw, 5rem) 0 0; padding: clamp(1.5rem, 4vw, 2.5rem);
    border: 1px solid var(--color-line-2); border-radius: 3px;
    background: linear-gradient(180deg, rgba(90,209,196,0.05), transparent 60%), var(--color-ink-2);
    max-width: 72ch;
  }
  .takes-kicker { margin-bottom: 1.2rem; color: var(--color-spark); }
  .takes-list { list-style: none; margin: 0; padding: 0; }
  .take { position: relative; padding-left: 1.6rem; margin-bottom: 1rem; color: var(--color-paper); font-size: clamp(1rem, 1.5vw, 1.12rem); line-height: 1.55; }
  .take:last-child { margin-bottom: 0; }
  .take::before { content: "→"; position: absolute; left: 0; color: var(--color-spark); }

  .note-next { margin-top: clamp(4rem, 9vw, 7rem); border-top: 1px solid var(--color-line); padding-top: 2.5rem; }
  .next-link { display: inline-flex; flex-direction: column; gap: 0.5rem; transition: transform 0.3s ease; }
  .next-link:hover { transform: translateX(8px); }
  .next-k { font-size: 0.78rem; color: var(--color-paper-mute); letter-spacing: 0.1em; }
  .next-title { font-size: clamp(1.8rem, 5vw, 2.8rem); color: var(--color-paper); }
  .next-link:hover .next-title { color: var(--color-spark); }
</style>
